PORT=3000
NVIDIA_API_KEY=your_nvidia_api_key
# MongoDB connection string (Atlas). Include a db name, e.g. .../campusdrive
MONGODB_URI=
# Long random string for signing login tokens (and encrypting stored API keys):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Optional: separate key for encrypting secrets at rest (defaults to JWT_SECRET).
# ENCRYPTION_KEY=
# Optional: lock CORS to your frontend origin(s), comma-separated, no trailing slash.
# FRONTEND_URL=https://campus-drive-frontend.onrender.com
