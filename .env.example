# ============================================================================
# Copy this file to ".env" and fill in real values. NEVER commit .env.
# ============================================================================

# --- LLM parser (existing) --------------------------------------------------
NVIDIA_API_KEY=

# --- App security -----------------------------------------------------------
# Long random string used to encrypt the Microsoft token cache at rest.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET_KEY=

# --- WhatsApp filtering -----------------------------------------------------
# Comma-separated chat IDs to listen to. Get them with: node tools/list-groups.js
# Only these chats are ever read — personal chats are ignored entirely.
WA_ALLOWED_CHATS=
# Require a keyword match even inside allowed groups (true/false).
WA_REQUIRE_KEYWORDS=true

# Keywords that mark a message/mail as placement-related (comma-separated).
# Leave blank to use the built-in defaults.
KEYWORDS=

# --- Google Sheet via Apps Script web app (easy, no Cloud Console) -----------
# Deploy tools/AppsScript.gs inside your sheet, then paste the Web app URL here.
GAS_WEBAPP_URL=
# Shared secret; must equal TOKEN in tools/AppsScript.gs.
GAS_TOKEN=

# --- Cloud persistence (Render/Koyeb) ---------------------------------------
# MongoDB connection string. Set this on the cloud host so the WhatsApp session
# and token cache survive restarts (Atlas free tier works, no card needed).
# Leave BLANK when running on your own always-on device (uses local disk).
MONGODB_URI=

# --- Paths ------------------------------------------------------------------
TOKEN_CACHE_PATH=./.secrets/graph_token_cache.enc

# --- Server / Chromium (set on the deployed server, not needed locally) -----
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
